# =====================================================================
# Patient data (NEVER commit) -- keep only .gitkeep placeholders
# =====================================================================
data/raw/*
!data/raw/.gitkeep
data/outputs/*
!data/outputs/.gitkeep
data/processed/
data/anonymized/
data/structured/

# =====================================================================
# Generated artifacts
# =====================================================================
/outputs/
reports/
plots/
logs/
*.log

# Tabular / document data (unless explicitly a synthetic fixture)
*.csv
*.xlsx
*.xls
*.parquet
*.jsonl
*.pdf
*.png

# =====================================================================
# Environments
# =====================================================================
tumor_venv/
Ba_venv/
Ba_venv_backup/
.venv/
venv/
env/

# =====================================================================
# Python artifacts
# =====================================================================
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# =====================================================================
# Secrets / local config
# =====================================================================
.env
*.env
*.token
*.key
*.pem

# =====================================================================
# Offline wheels / models
# =====================================================================
# NOTE: wheelhouse/ is intentionally COMMITTED so the air-gapped server can
# install dependencies offline (pip --no-index --find-links=wheelhouse).
# Do not ignore it. Large archives and model blobs stay out of git.
*.tar.gz
*.zip
wheelhouse_linux/
wheelhouse_linux.zip
models/
models_Qwen/
models_Ollama/

# =====================================================================
# System / editor
# =====================================================================
.DS_Store
.vscode/
.idea/

# =====================================================================
# Placeholders to keep folder structure
# =====================================================================
!.gitkeep
